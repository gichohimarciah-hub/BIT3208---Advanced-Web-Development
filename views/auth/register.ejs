<%- include('../partials/header') %>

<div class="auth-box">
  <h2>Create an Account</h2>

  <% if (error) { %>
    <div class="alert alert-error"><%= error %></div>
  <% } %>
  <% if (success) { %>
    <div class="alert alert-success"><%= success %></div>
  <% } %>

  <form action="/auth/register" method="POST" id="regForm">
    <div class="form-group">
      <label>Full Name</label>
      <input type="text" name="name" placeholder="Marciah Wanjiku" required />
    </div>
    <div class="form-group">
      <label>Email Address</label>
      <input type="email" name="email" placeholder="you@example.com" required />
    </div>
    <div class="form-group">
      <label>Password</label>
      <input type="password" name="password" id="pw" placeholder="Min 6 characters" required />
      <div class="strength-bar"><div id="strengthFill"></div></div>
      <small id="strengthText" class="form-hint"></small>
    </div>
    <div class="form-group">
      <label>Confirm Password</label>
      <input type="password" name="confirmPassword" id="cpw" placeholder="Repeat password" required />
      <small id="matchMsg" class="form-hint"></small>
    </div>
    <button type="submit" class="btn-primary full">Register</button>
  </form>

  <p class="auth-link">Already have an account? <a href="/auth/login">Login</a></p>
</div>

<script>
  // Password strength checker (Week 3 JS requirement)
  const pw  = document.getElementById('pw');
  const cpw = document.getElementById('cpw');

  pw.addEventListener('input', () => {
    const v = pw.value;
    const fill = document.getElementById('strengthFill');
    const text = document.getElementById('strengthText');
    let pct = 0, label = '', color = '';
    if (v.length >= 6)  { pct = 33; label = 'Weak';   color = '#e74c3c'; }
    if (v.length >= 8 && /[A-Z]/.test(v)) { pct = 66; label = 'Good';   color = '#f39c12'; }
    if (v.length >= 10 && /[A-Z]/.test(v) && /[0-9]/.test(v) && /[^a-zA-Z0-9]/.test(v)) {
      pct = 100; label = 'Strong'; color = '#27ae60';
    }
    fill.style.width = pct + '%';
    fill.style.background = color;
    text.textContent = v.length ? label : '';
    text.style.color = color;
  });

  cpw.addEventListener('input', () => {
    const msg = document.getElementById('matchMsg');
    if (cpw.value === pw.value) { msg.textContent = '✅ Passwords match'; msg.style.color = '#27ae60'; }
    else                        { msg.textContent = '❌ Passwords do not match'; msg.style.color = '#e74c3c'; }
  });

  document.getElementById('regForm').addEventListener('submit', (e) => {
    if (cpw.value !== pw.value) { e.preventDefault(); }
  });
</script>

<%- include('../partials/footer') %>
