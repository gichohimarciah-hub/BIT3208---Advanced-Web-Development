<%- include('partials/header') %>

<section class="hero">
  <h1>Welcome to SmartShop</h1>
  <p>Your one-stop tech store. Browse the latest electronics and accessories.</p>
  <a href="/products" class="btn-primary">Shop Now</a>
  <% if (!locals.user) { %>
    <a href="/auth/register" class="btn-secondary">Create Account</a>
  <% } %>
</section>

<section class="section">
  <h2>Featured Products</h2>
  <div class="product-grid">
    <% products.forEach(p => { %>
      <div class="product-card">
        <div class="product-icon">📦</div>
        <h3><%= p.name %></h3>
        <p class="product-cat"><%= p.category %></p>
        <p class="product-price">KES <%= Number(p.price).toLocaleString() %></p>
        <a href="/products/<%= p.id %>" class="btn-primary small">View Details</a>
      </div>
    <% }) %>
  </div>
</section>

<%- include('partials/footer') %>
