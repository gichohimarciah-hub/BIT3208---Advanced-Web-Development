<%- include('../partials/header') %>

<div class="page-header">
  <h2>All Products</h2>
  <form action="/products" method="GET" class="search-form">
    <input type="text" name="search" placeholder="Search products..." value="<%= search %>" />
    <select name="category">
      <option value="">All Categories</option>
      <% categories.forEach(c => { %>
        <option value="<%= c.category %>" <%= category === c.category ? 'selected' : '' %>>
          <%= c.category %>
        </option>
      <% }) %>
    </select>
    <button type="submit" class="btn-primary">Search</button>
  </form>
</div>

<% if (products.length === 0) { %>
  <p class="empty-msg">No products found.</p>
<% } else { %>
  <div class="product-grid">
    <% products.forEach(p => { %>
      <div class="product-card">
        <% if (p.image_url) { %>
  <img src="<%= p.image_url %>" alt="<%= p.name %>" style="width:100%;height:180px;object-fit:cover;border-radius:8px;" />
<% } else { %>
  <div class="product-icon">🛍️</div>
<% } %>
        <span class="badge"><%= p.category %></span>
        <h3><%= p.name %></h3>
        <p class="product-desc"><%= p.description ? p.description.substring(0, 70) + '...' : '' %></p>
        <p class="product-price">KES <%= Number(p.price).toLocaleString() %></p>
        <p class="stock-info">Stock: <%= p.stock %></p>
        <a href="/products/<%= p.id %>" class="btn-primary small">View</a>
      </div>
    <% }) %>
  </div>
<% } %>

<%- include('../partials/footer') %>
